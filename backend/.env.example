# ==============================================================================
# CP Agenda Pro — Environment Variables
# ==============================================================================
# INSTRUCTIONS:
#   1. Copy this file to: backend/.env
#   2. Fill in the values for your environment
#   3. NEVER commit the .env file — it is in .gitignore
#   4. The .env file MUST exist on the production server with correct values
# ==============================================================================

# --- Database (Required) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password
DB_CHARSET=utf8mb4

# --- App ---
API_VERSION=1.0.0

# --- Security ---
# Set to 'false' in production — NEVER 'true' on a live server
DEBUG_MODE=false

# --- Telegram Bot ---
# Token from @BotFather. Required for appointment push notifications (per-professional).
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Dedicated bot for SYSTEM ERROR MONITORING (separate from appointment notifications).
# Create a separate bot via @BotFather for this purpose.
TELEGRAM_MONITOR_TOKEN=your_monitoring_bot_token_here

# Your personal Telegram Chat ID (destination for error alerts).
# Send /start to @userinfobot to get your Chat ID.
TELEGRAM_ERROR_CHAT_ID=your_personal_chat_id

# --- Email (SMTP) ---
# Used for password reset and welcome emails. Configure in GitHub Secrets.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=your@email.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=your@email.com
SMTP_FROM_NAME=CP Agenda Pro
