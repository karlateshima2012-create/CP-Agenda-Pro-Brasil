# ==============================================================================
# CP Agenda Pro — Backend Node.js — Variáveis de Ambiente
# ==============================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo para: backend-node/.env
#   2. Preencha os valores para o seu ambiente
#   3. NUNCA commite o arquivo .env — ele está no .gitignore
# ==============================================================================

# --- Servidor ---
PORT=3000
NODE_ENV=production

# --- Banco de Dados (Hostinger MySQL) ---
DATABASE_URL="mysql://USUARIO:SENHA@localhost:3306/NOME_DO_BANCO"

# --- JWT (Segurança) ---
# Gere com: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
# Ou: openssl rand -hex 64
JWT_SECRET="SUBSTITUA_POR_CHAVE_ALEATORIA_DE_64_BYTES_HEX"

# --- CORS — origens permitidas (separar por vírgula) ---
ALLOWED_ORIGINS="https://seudominio.com,http://localhost:5173"

# --- URL do App (para links de e-mail) ---
APP_URL="https://seudominio.com"

# --- SMTP (E-mail) ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=seu@email.com
SMTP_PASSWORD=sua_senha_smtp
SMTP_FROM=seu@email.com
SMTP_FROM_NAME=CP Agenda Pro

# --- Telegram (monitoramento de erros — bot dedicado, separado do bot de notificações) ---
TELEGRAM_MONITOR_TOKEN=
TELEGRAM_ERROR_CHAT_ID=
