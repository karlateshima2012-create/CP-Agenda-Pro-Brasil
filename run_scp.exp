#!/usr/bin/expect -f
set timeout 120
set host "76.13.209.192"
set port "22"
set user "root"
set password [lindex $argv 0]
set local_file [lindex $argv 1]
set remote_path [lindex $argv 2]

spawn scp -P $port -o StrictHostKeyChecking=no $local_file $user@$host:$remote_path
expect {
    "password:" {
        send "$password\r"
        exp_continue
    }
    timeout {
        puts "Timeout reached"
        exit 1
    }
    eof
}
catch wait result
exit [lindex $result 3]
